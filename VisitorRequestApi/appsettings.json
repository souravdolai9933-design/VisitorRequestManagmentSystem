{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Error"
    },

    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/error-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ]
  },

  "Jwt": {
    "Key": "ThisIsMySecretKeyForJwtToken12345",
    "Issuer": "VisitorRequestApi",
    "Audience": "VisitorRequestMvc",
    "ExpireMinutes": 60
  },

  "ConnectionStrings": {
    "MyDbConnection": "Server=localhost;Database=VisitorRequestDatabase;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "AllowedHosts": "*"
}